# Dynamic theme colors
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = "JetBrainsMono Nerd Font"
font-style = Regular
font-size = 12
custom-shader = ./ghostty-cursor-shaders/cursor_warp.glsl
custom-shader = ./ghostty-cursor-shaders/ripple_cursor.glsl

# Window
window-theme = dark 
window-padding-x = 2
window-padding-y = 2
confirm-close-surface=false
resize-overlay = never
gtk-toolbar-style = flat
# ~/.config/ghostty/config

# Cursor styling
cursor-style = "block"
cursor-style-blink = false
# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env
window-padding-color = extend-always
background-image-opacity = 0.0
# Keyboard bindings
keybind = control+p=paste_from_clipboard
keybind = control+y=copy_to_clipboard
keybind = super+control+shift+alt+arrow_down=resize_split:down,100
keybind = super+control+shift+alt+arrow_up=resize_split:up,100
keybind = super+control+shift+alt+arrow_left=resize_split:left,100
keybind = super+control+shift+alt+arrow_right=resize_split:right,100
# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95
